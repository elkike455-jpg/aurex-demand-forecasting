# AUREX web
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_STRIPE_ENABLED=false

# AUREX API
AUREX_WEB_ORIGIN=http://127.0.0.1:5174
DATABASE_URL=postgresql://aurex:aurex@localhost:5432/aurex
SESSION_SECRET=replace-with-a-long-random-value

# Stripe - backend only
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Receipt email - backend only
# Works with SMTP providers such as Gmail app passwords, SendGrid SMTP, Mailgun SMTP, Brevo, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=replace-me
SMTP_PASSWORD=replace-me
SMTP_FROM=tickets@aurex.local
AUREX_RECEIPT_OUTBOX=outbox/receipts
